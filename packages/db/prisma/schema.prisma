generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id           Int                    @id @default(autoincrement())
  firstname    String
  lastname     String
  username     String                 @unique
  password     String
  keys         keys[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  notification notification_Message[]
}

model notification_Message {
  id               Int                @id @default(autoincrement())
  message          String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  UserID           Int
  user             users              @relation(fields: [UserID], references: [id])
  logs_and_updates logs_and_updates[]
}

model keys {
  id            Int      @id @default(autoincrement())
  discord       String?
  discordtoken  String?
  email         String?
  emailtoken    String
  whatsappkey   String?
  whatsapptoken String?
  otherkey      String
  othertoken    String?
  UserID        Int
  user          users    @relation(fields: [UserID], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum notification {
  pending
  processing
  done
  failed
  retrying
}

model logs_and_updates {
  id        Int                  @id @default(autoincrement())
  message   String
  updates   notification
  usermsgid Int
  msg       notification_Message @relation(fields: [usermsgid], references: [id])
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

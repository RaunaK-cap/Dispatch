generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id                  Int                   @id @default(autoincrement())
  firstname           String
  lastname            String
  username            String                @unique
  password            String
  notificationmessage notificationmessage[]
  deliverylogs        deliverylog[]
  channelconfig       channelconfig[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
}

enum channeltype {
  DISCORD
  EMAIL
  WHATSAPP
  TELEGRAM
}

model channelconfig {
  id        Int         @id @default(autoincrement())
  channel   channeltype
  config    Json
  isactive  Boolean     @default(false)
  USERID    Int
  user      user        @relation(fields: [USERID], references: [id])
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model notificationmessage {
  id           Int           @id() @default(autoincrement())
  message      String
  USERID       Int
  user         user          @relation(fields: [USERID], references: [id])
  deliverylogs deliverylog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum deliverystatus {
  PENDING
  QUEUED
  PROCESSING
  DELIVERED
  PARTIALLY_DELIVERED
  FAILED
  CANCELLED
}

model deliverylog {
  id         Int                 @id @default(autoincrement())
  messageID  Int
  messagesid notificationmessage @relation(fields: [messageID], references: [id])
  USERID     Int
  user       user                @relation(fields: [USERID], references: [id])
  channel    channeltype?
  status     deliverystatus      @default(PENDING)
  retrycount Int
  redisjobID String?
  latencyMS  Int?
  createdAt  DateTime            @default(now())
  updateAt   DateTime            @updatedAt
}
